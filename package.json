{
  "name": "gdl-games",
  "version": "0.0.0",
  "private": true,
  "description": "Monorepo of Nexus Mods Vortex game extensions, built from a single shared GDL toolchain.",
  "license": "GPL-3.0-or-later",
  "packageManager": "pnpm@11.0.9",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "init-gdl": "cd gdl && pnpm install && pnpm build",
    "build": "nx run-many -t build",
    "test": "nx run-many -t test",
    "test:corpus": "nx run-many -t test-corpus",
    "package": "nx run-many -t package",
    "affected": "nx affected"
  },
  "devDependencies": {
    "nx": "^22.7.5",
    "vitest": "^4.1.10"
  }
}
