{
  "name": "gdl-games",
  "version": "0.0.0",
  "private": true,
  "description": "Monorepo of Nexus Mods Vortex game extensions, built from a single shared GDL toolchain.",
  "license": "GPL-3.0-or-later",
  "packageManager": "pnpm@11.0.9",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "init-gdl": "cd gdl && pnpm install && pnpm build",
    "build": "node scripts/run-gdl.mjs build",
    "test": "node scripts/run-gdl.mjs build && vitest run",
    "test:corpus": "node scripts/run-gdl.mjs test:corpus",
    "package": "node scripts/run-gdl.mjs package"
  },
  "devDependencies": {
    "vitest": "^3.0.0"
  }
}
